{
  "name": "boltcard-poc",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@playwright/test": "^1.60.0",
    "better-sqlite3": "12.9.0",
    "fast-check": "^4.7.0",
    "miniflare": "4.20260116.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.59.3"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@noble/secp256k1": "3.1.0",
    "@scure/base": "^2.2.0",
    "aes-js": "3.1.2",
    "itty-router": "5.0.23",
    "valibot": "^1.3.1"
  },
  "scripts": {
    "prebuild": "node scripts/build_keys.js",
    "test": "vitest run",
    "test:do": "vitest run --config vitest.do.config.js",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:all": "npm test && npm run test:do && npm run test:integration",
    "typecheck": "tsc --noEmit",
    "typecheck:src": "tsc --noEmit --project tsconfig.build.json",
    "lint:innerhtml": "node scripts/check-innerhtml.js",
    "live:smoke": "node scripts/live-smoke-test.mjs",
    "cf-typegen": "wrangler types",
    "deploy": "npm test && npm run test:do && npm run test:integration && npm run typecheck && npm run lint:innerhtml && node scripts/build_keys.js && wrangler deploy && npm run live:smoke"
  }
}
