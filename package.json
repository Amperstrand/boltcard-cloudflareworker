{
  "name": "boltcard-poc",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "better-sqlite3": "12.9.0",
    "miniflare": "4.20260116.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "4.59.3"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@noble/secp256k1": "3.1.0",
    "@scure/base": "^2.2.0",
    "aes-js": "3.1.2",
    "itty-router": "5.0.23"
  },
  "scripts": {
    "prebuild": "node scripts/build_keys.js",
    "test": "vitest run",
    "test:do": "vitest run --config vitest.do.config.js",
    "test:all": "npm test && npm run test:do",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "npm test && npm run test:do && npm run typecheck && node scripts/build_keys.js && wrangler deploy"
  }
}
